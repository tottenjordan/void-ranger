# Void Ranger — Deep Field GCP provisioning config (Phase 2G)
#
# Copy this file to `config.env` and fill in your own values, then run the
# numbered scripts in order (00 -> 10 -> 20 -> 30). See DEPLOY.md.
#
#   cp config.env.example config.env
#   $EDITOR config.env
#
# config.env is git-ignored intentionally (it holds your project-specific
# values). Every script sources it and fails with a clear message if missing.
# No value here is hardcoded in the scripts — change everything from this file.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Your GCP project id (NOT the display name/number). e.g. my-voidranger-proj
PROJECT_ID="your-gcp-project-id"

# Compute/region for the GCS bucket and Cloud Run service. e.g. us-central1
REGION="us-central1"

# BigQuery dataset location. Multi-region "US"/"EU" or a region like
# "us-central1". Must be compatible with where you read/extract. e.g. US
BQ_LOCATION="US"

# GCS bucket that holds raw catalog + built Deep Field assets. Globally unique,
# no gs:// prefix. e.g. voidranger-deepfield-assets
BUCKET="your-unique-bucket-name"

# BigQuery dataset name (lives in PROJECT_ID). e.g. glade
BQ_DATASET="glade"

# The browser origin allowed to fetch assets via CORS (your deployed frontend).
# Scheme + host (+ port if non-standard), NO trailing slash.
# e.g. https://voidranger.example.com  or  http://localhost:5173 for local test
APP_ORIGIN="https://your-frontend-origin.example.com"

# Cloud Run service name (only used if you serve the grid from the backend in
# 30_serve.sh option (c)). e.g. voidranger-api
SERVICE_NAME="voidranger-api"

# Deep Field cube bound in Mpc. Galaxies with luminosity distance d_L <= R_MAX
# are kept. Must match the value used to build the committed sample (500).
R_MAX_MPC="500"

# ---------------------------------------------------------------------------
# Optional (sane defaults applied by the scripts if unset)
# ---------------------------------------------------------------------------

# Local path to the real fixed-width GLADE+ catalog (VizieR VII/291 gladep.dat,
# ~23.2M rows, ~14 GB). Downloaded by you; not committed. Required by
# 10_load_bigquery.sh to populate BigQuery. e.g. ./gladep.dat
GLADE_DAT="./gladep.dat"

# Least-privilege service account id (the part before @). Created by 00_setup.sh
# if absent. e.g. voidranger-deploy
SERVICE_ACCOUNT="voidranger-deploy"

# Object prefix under the bucket for the public Deep Field assets. The frontend's
# VITE_ASSET_BASE_URL points at <asset base>/<ASSET_PREFIX>. e.g. deepfield
ASSET_PREFIX="deepfield"

# Cache-Control applied to uploaded assets (immutable, long-lived). The tile/
# grid filenames are content-stable for a given build, so a long TTL is safe.
ASSET_CACHE_CONTROL="public, max-age=31536000, immutable"

# Value of the "solution" label applied to every GCP resource the suite creates
# whose type supports labels (-> solution=<SOLUTION_LABEL>). Lets you find,
# group, and attribute all Void Ranger assets in billing. Defaults to void-ranger.
SOLUTION_LABEL="void-ranger"

# Deep Field grid resolution: voxels per axis. Build cost and grid size scale as
# N³. MUST stay 48 to remain byte-identical to the committed sample grid (so no
# re-upload is ever needed); lower it only for fast dry runs. Default 48.
GRID_N="48"

# Parallel worker processes for the grid build. Blank = build_grid.py auto-picks
# os.cpu_count(). Output is byte-identical regardless of job count (workers split
# voxel ranges, not the per-voxel galaxy sum). e.g. 8
GRID_JOBS=""
